{
  "compilerOptions": {
    "module": "Node16",
    //  "outDir": "./dist",
    // "rootDir": "./src",
    "moduleResolution": "Node16",
    "target": "ES2020",
    "types": [
      "node"
    ],
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": [
    "**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}